<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/titan_card_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tasker Plugin Setup"
        android:textColor="@color/titan_primary_label"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="This plugin requires Tasker to work. Follow these steps:"
        android:textColor="@color/titan_secondary_label"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="1. Download Tasker from the Play Store"
        android:textColor="@color/titan_primary_label"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="2. Open the TaskerNet link below to import the profile"
        android:textColor="@color/titan_primary_label"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="3. When Tasker asks to import the profile, tap YES"
        android:textColor="@color/titan_primary_label"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="4. Grant any permissions Tasker requests"
        android:textColor="@color/titan_primary_label"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="5. Enable the profile in Tasker's profile list"
        android:textColor="@color/titan_primary_label"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="The plugin allows Gemini or ChatGPT image questions to work with your glasses through Tasker automation."
        android:textColor="@color/titan_secondary_label"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_download_tasker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Download Tasker"
            android:backgroundTint="@color/titan_primary_button_tint"
            android:textColor="@color/titan_button_text" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_open_taskernet"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Open TaskerNet Profile"
        android:textColor="@color/titan_primary" />

    <Button
        android:id="@+id/btn_close"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Close"
        android:textColor="@color/titan_secondary_label" />

</LinearLayout>
